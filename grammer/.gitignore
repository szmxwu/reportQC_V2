# ============================================
# 医学错别字检测模块 - Git 忽略配置
# ============================================

# --------------------------------------------
# 训练资源文件 (Training Resources)
# 这些文件可以通过训练流程重新生成
# --------------------------------------------

# 原始语料库
train/
models/radiology_corpus.txt
models/sentence_corpus.sqlite3
models/sentence_corpus_stats.json

# ARPA 格式模型 (训练中间产物，可由 KLM 转换)
models/radiology_ngram.arpa

# 扩展候选词文件 (训练中间产物)
models/expanded_candidates.json

# 子串词表 (训练生成的临时文件)
models/substring_vocab.json

# --------------------------------------------
# 大模型文件原始版本 (已压缩，保留压缩后的版本)
# 解压方法: cat models/radiology_ngram.klm.part.* | tar -xzf -
# --------------------------------------------
models/*.klm
models/*.pkl

# --------------------------------------------
# KenLM 源代码和编译产物
# --------------------------------------------
kenlm/build/
kenlm/python/kenlm.cpp
kenlm/**/*.o
kenlm/**/*.a
kenlm/**/*.so

# --------------------------------------------
# Python 运行时文件
# --------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# --------------------------------------------
# 临时文件
# --------------------------------------------
temp_chunks/
*.tmp
*.log

# --------------------------------------------
# 系统文件
# --------------------------------------------
.DS_Store
Thumbs.db
