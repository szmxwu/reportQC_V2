# Embedding & Rerank API 配置 (xinferrence)
XINFERENCE_BASE_URL=http://192.0.0.188:9997/v1
XINFERENCE_API_KEY=

# 模型名称
EMBEDDING_MODEL=bge-large-zh-v1.5
RERANK_MODEL=bge-reranker-v2-m3

# 性能参数
EMBEDDING_CACHE_SIZE=1000
API_TIMEOUT=10
MAX_RERANK_CANDIDATES=5

# 相似度阈值
RERANK_THRESHOLD=0.7
EMBEDDING_THRESHOLD=0.5

# 功能开关
USE_BGE_RERANK=true
USE_LLM_VALIDATION=true

# LLM配置 (qwen3)
LLM_BASE_URL=http://192.0.0.193:9997/v1
LLM_MODEL=qwen3
LLM_API_KEY=
LLM_TIMEOUT=30
LLM_MAX_TOKENS=2048
LLM_BATCH_SIZE=5
LLM_CONFIDENCE_THRESHOLD=0.7
LLM_CACHE_SIZE=500

# 降级策略
FALLBACK_TO_WORD2VEC=true

# API服务配置
API_HOST=0.0.0.0
API_PORT=8000
